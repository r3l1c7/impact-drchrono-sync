# ─────────────────────────────────────────────
# ImPACT API
# ─────────────────────────────────────────────
IMPACT_BASE_URL=https://mobile.impacttestonline.com/impactAPI/
IMPACT_PUBLIC_API_KEY=your_public_key
IMPACT_PRIVATE_API_KEY=your_private_key
IMPACT_LOCATION_CODE=US
IMPACT_USER_TOKEN=your_user_token
IMPACT_ORG_ID=your_org_id

# ─────────────────────────────────────────────
# DrChrono OAuth2
# ─────────────────────────────────────────────
DRCHRONO_CLIENT_ID=your_client_id
DRCHRONO_CLIENT_SECRET=your_client_secret
DRCHRONO_ACCESS_TOKEN=your_access_token
DRCHRONO_REFRESH_TOKEN=your_refresh_token
DRCHRONO_DOCTOR_ID=your_doctor_id

# ─────────────────────────────────────────────
# Sync Settings
# ─────────────────────────────────────────────
SYNC_CRON=*/15 * * * *
LOOKBACK_HOURS=24
SYNC_CUTOFF_DATE=2026-04-01
LOG_LEVEL=info
